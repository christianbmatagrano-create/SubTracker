# Supabase — get from https://app.supabase.com → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Resend — get from https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key

# Your verified sender email in Resend (must be from a domain you own OR onboarding@resend.dev for testing)
RESEND_FROM_EMAIL=reminders@yourdomain.com

# Cron security secret — generate any random string: openssl rand -hex 32
CRON_SECRET=your-random-secret-here
